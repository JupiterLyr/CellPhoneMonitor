<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:text="@string/local_time_format"
            android:textColor="@color/text_main"
            android:textSize="@dimen/text_size_xlarge"
            android:textStyle="bold" />

            <View
                android:layout_width="64dp"
                android:layout_height="4dp"
                android:layout_gravity="center"
                android:layout_marginVertical="24dp"
                android:background="@color/blue_main" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/title"
                android:textColor="@color/text_main"
                android:textSize="@dimen/text_size_xlarge"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBattery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:text="@string/battery_percentage"
                android:textColor="@color/text_main"
                android:textSize="@dimen/text_size_xlarge"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/progressBattery"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginVertical="12dp"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_battery" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardBackgroundColor="@color/black"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp"
                            app:cardUseCompatPadding="false"
                            app:strokeColor="@color/gray"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="@string/charging_status_title"
                                    android:textColor="@color/text_description"
                                    android:textSize="@dimen/text_size_small" />

                                <TextView
                                    android:id="@+id/tvCharging"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:layout_marginTop="6dp"
                                    android:text="@string/charger_condition"
                                    android:textColor="@color/text_main"
                                    android:textSize="@dimen/text_size_medium"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            app:cardBackgroundColor="@color/black"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp"
                            app:cardUseCompatPadding="false"
                            app:strokeColor="@color/gray"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="@string/battery_temperature_title"
                                    android:textColor="@color/text_description"
                                    android:textSize="@dimen/text_size_small" />

                                <TextView
                                    android:id="@+id/tvBatteryTemp"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:layout_marginTop="6dp"
                                    android:text="@string/charger_temperature"
                                    android:textColor="@color/text_main"
                                    android:textSize="@dimen/text_size_medium"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardBackgroundColor="@color/black"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp"
                            app:cardUseCompatPadding="false"
                            app:strokeColor="@color/gray"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="@string/thermal_status_title"
                                    android:textColor="@color/text_description"
                                    android:textSize="@dimen/text_size_small" />

                                <TextView
                                    android:id="@+id/tvThermalStatus"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:layout_marginTop="6dp"
                                    android:text="@string/thermal_status"
                                    android:textColor="@color/text_main"
                                    android:textSize="@dimen/text_size_medium"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            app:cardBackgroundColor="@color/black"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp"
                            app:cardUseCompatPadding="false"
                            app:strokeColor="@color/gray"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="@string/battery_current_title"
                                    android:textColor="@color/text_description"
                                    android:textSize="@dimen/text_size_small" />

                                <TextView
                                    android:id="@+id/tvBatteryCurrent"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:layout_marginTop="6dp"
                                    android:text="@string/battery_current"
                                    android:textColor="@color/text_main"
                                    android:textSize="@dimen/text_size_medium"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardBackgroundColor="@color/black"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp"
                            app:cardUseCompatPadding="false"
                            app:strokeColor="@color/gray"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="@string/battery_voltage_title"
                                    android:textColor="@color/text_description"
                                    android:textSize="@dimen/text_size_small" />

                                <TextView
                                    android:id="@+id/tvBatteryVoltage"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:layout_marginTop="6dp"
                                    android:text="@string/battery_voltage"
                                    android:textColor="@color/text_main"
                                    android:textSize="@dimen/text_size_medium"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            app:cardBackgroundColor="@color/black"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp"
                            app:cardUseCompatPadding="false"
                            app:strokeColor="@color/gray"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="@string/battery_power_title"
                                    android:textColor="@color/text_description"
                                    android:textSize="@dimen/text_size_small" />

                                <TextView
                                    android:id="@+id/tvBatteryPower"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:layout_marginTop="6dp"
                                    android:text="@string/battery_power"
                                    android:textColor="@color/text_main"
                                    android:textSize="@dimen/text_size_medium"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardBackgroundColor="@color/black"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp"
                            app:cardUseCompatPadding="false"
                            app:strokeColor="@color/gray"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="@string/screen_refresh_rate"
                                    android:textColor="@color/text_description"
                                    android:textSize="@dimen/text_size_small" />

                                <TextView
                                    android:id="@+id/tvRefreshRate"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:layout_marginTop="6dp"
                                    android:text="@string/refresh_rate"
                                    android:textColor="@color/text_main"
                                    android:textSize="@dimen/text_size_medium"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            app:cardBackgroundColor="@color/black"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp"
                            app:cardUseCompatPadding="false"
                            app:strokeColor="@color/gray"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="@string/cpu_temperature_title"
                                    android:textColor="@color/text_description"
                                    android:textSize="@dimen/text_size_small" />

                                <TextView
                                    android:id="@+id/tvCpuTemp"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:layout_marginTop="6dp"
                                    android:text="@string/cpu_temperature"
                                    android:textColor="@color/text_main"
                                    android:textSize="@dimen/text_size_medium"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardBackgroundColor="@color/black"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:cardUseCompatPadding="false"
                        app:strokeColor="@color/gray"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="@string/cpu_frequency_title"
                                android:textColor="@color/text_description"
                                android:textSize="@dimen/text_size_small" />

                            <TextView
                                android:id="@+id/tvCpuFreq"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:layout_marginTop="6dp"
                                android:text="@string/cpu_frequency"
                                android:textColor="@color/text_main"
                                android:textSize="@dimen/text_size_medium"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardBackgroundColor="@color/black"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:cardUseCompatPadding="false"
                        app:strokeColor="@color/gray"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="@string/memory_usage_title"
                                android:textColor="@color/text_description"
                                android:textSize="@dimen/text_size_small" />

                            <TextView
                                android:id="@+id/tvMemoryload"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:layout_marginTop="6dp"
                                android:text="@string/memory_usage"
                                android:textColor="@color/text_main"
                                android:textSize="@dimen/text_size_medium"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
    </LinearLayout>

</ScrollView>